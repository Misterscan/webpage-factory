{
  "name": "webpage-factory",
  "version": "1.1.0",
  "description": "A Sesi project for building webpages.",
  "main": "node_modules/@misterscan/sesi/dist/index.js",
  "bin": {
    "sesi": "bin/sesi.js"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "sesi": "sesi",
    "start": "sesi -l main.sesi",
    "demo": "sesi -l demo/demo.sesi",
    "eval": "sesi -e",
    "help": "sesi -h",
    "support": "sesi chatbot/sesi_db_chatbot.sesi",
    "lint": "sesi bin/lint.sesi",
    "encrypt": "sesi -enc",
    "decrypt": "sesi -dec",
    "server": "sesi server.sesi -l"
  },
  "dependencies": {
    "@misterscan/sesi": "1.5.6"
  },
  "keywords": [
    "sesi",
    "webpage",
    "factory",
    "template",
    "generator"
  ],
  "author": "Misterscan",
  "homepage": "https://github.com/Misterscan/webpage-factory",
  "allowScripts": {
    "@google/genai@2.8.0": true,
    "fsevents@2.3.2": true,
    "protobufjs@7.6.4": true
  }
}
