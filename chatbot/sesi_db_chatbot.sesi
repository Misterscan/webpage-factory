/* 
  Sesi Co-Pilot
  Dynamically indexes the sesi-db knowledge base, trains on-the-fly, and answers queries! 
*/

/* 
  ==================================================
  💬 1. CHOOSE YOUR ADVANCED TECHNICAL QUERY HERE!
  (Test it with custom phrases containing our keywords!) 
*/
let queryText = ""
let fileContext = ""

if len(args) > 0 {
  queryText = args[0]
  if len(args) > 1 {
    try {
      fileContext = "File: " + args[1] + "\n\n" + read_file(args[1])
    } catch (e) {}
  }
} else {
  queryText = input("Enter your question: ")
}
// ==================================================

print "Loading Sesi Co-Pilot..."

// Sigmoid math activation
fn activate(x) {
  return 1.0 / (1.0 + exp(0.0 - x))
}

// Sigmoid derivative for backpropagation
fn derivative(y) {
  return y * (1.0 - y)
}

/* 
  89-Dimensional Bag-of-Words Vocabulary Vectorizer
  Tracks only official Sesi language keywords, compiler builtins, and native standard library exports. 
*/
fn vectorize(text) {
  let vec = []
  let k = 0
  while k < 89 {
    push(vec, 0.0)
    k = k + 1
  }
  
  let raw_words = split(text, " ")
  let words = []
  
  let w = 0
  let num_raw = len(raw_words)
  while w < num_raw {
    let word = raw_words[w]
    let parts_nl = split(word, "\n")
    let p = 0
    while p < len(parts_nl) {
      let sub_word1 = parts_nl[p]
      let parts_t = split(sub_word1, "\t")
      let t = 0
      while t < len(parts_t) {
        let sub_word2 = parts_t[t]
        let chars = split(sub_word2, "")
        let clean_tok = ""
        let c = 0
        while c < len(chars) {
          let char = chars[c]
          if char != "(" {
            if char != ")" {
              if char != "{" {
                if char != "}" {
                  if char != "[" {
                    if char != "]" {
                      if char != ";" {
                        if char != "," {
                          if char != "\r" {
                            if char != "\"" {
                              if char != "'" {
                                clean_tok = clean_tok + char
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
          c = c + 1
        }
        if len(clean_tok) > 0 {
          push(words, clean_tok)
        }
        t = t + 1
      }
      p = p + 1
    }
    w = w + 1
  }

  let i = 0
  while i < len(words) {
    let tok = words[i]
    if tok == "print" { vec[0] = 1.0 }
    if tok == "str" { vec[1] = 1.0 }
    if tok == "type" { vec[2] = 1.0 }
    if tok == "num" { vec[3] = 1.0 }
    if tok == "bool" { vec[4] = 1.0 }
    if tok == "from_json" { vec[5] = 1.0 }
    if tok == "to_json" { vec[6] = 1.0 }
    if tok == "len" { vec[7] = 1.0 }
    if tok == "read_file" { vec[8] = 1.0 }
    if tok == "write_file" { vec[9] = 1.0 }
    if tok == "write_image" { vec[10] = 1.0 }
    if tok == "list_dir" { vec[11] = 1.0 }
    if tok == "make_dir" { vec[12] = 1.0 }
    if tok == "exp" { vec[13] = 1.0 }
    if tok == "random" { vec[14] = 1.0 }
    if tok == "let" { vec[15] = 1.0 }
    if tok == "const" { vec[16] = 1.0 }
    if tok == "fn" { vec[17] = 1.0 }
    if tok == "if" { vec[18] = 1.0 }
    if tok == "else" { vec[19] = 1.0 }
    if tok == "while" { vec[20] = 1.0 }
    if tok == "for" { vec[21] = 1.0 }
    if tok == "return" { vec[22] = 1.0 }
    if tok == "break" { vec[23] = 1.0 }
    if tok == "continue" { vec[24] = 1.0 }
    if tok == "try" { vec[25] = 1.0 }
    if tok == "catch" { vec[26] = 1.0 }
    if tok == "finally" { vec[27] = 1.0 }
    if tok == "import" { vec[28] = 1.0 }
    if tok == "export" { vec[29] = 1.0 }
    if tok == "memory" { vec[30] = 1.0 }
    if tok == "sleep" { vec[31] = 1.0 }
    if tok == "now" { vec[32] = 1.0 }
    if tok == "model" { vec[33] = 1.0 }
    if tok == "image" { vec[34] = 1.0 }
    if tok == "structured_output" { vec[35] = 1.0 }
    if tok == "tool_call" { vec[36] = 1.0 }
    if tok == "spawn" { vec[37] = 1.0 }
    if tok == "exec" { vec[38] = 1.0 }
    if tok == "time" { vec[39] = 1.0 }
    if tok == "range" { vec[40] = 1.0 }
    if tok == "push" { vec[41] = 1.0 }
    if tok == "pop" { vec[42] = 1.0 }
    if tok == "join" { vec[43] = 1.0 }
    if tok == "split" { vec[44] = 1.0 }
    if tok == "keys" { vec[45] = 1.0 }
    if tok == "values" { vec[46] = 1.0 }
    if tok == "array" { vec[47] = 1.0 }
    if tok == "PI" { vec[48] = 1.0 }
    if tok == "E" { vec[49] = 1.0 }
    if tok == "sin" { vec[50] = 1.0 }
    if tok == "cos" { vec[51] = 1.0 }
    if tok == "tan" { vec[52] = 1.0 }
    if tok == "sqrt" { vec[53] = 1.0 }
    if tok == "floor" { vec[54] = 1.0 }
    if tok == "ceil" { vec[55] = 1.0 }
    if tok == "abs" { vec[56] = 1.0 }
    if tok == "pow" { vec[57] = 1.0 }
    if tok == "log" { vec[58] = 1.0 }
    if tok == "parse" { vec[59] = 1.0 }
    if tok == "stringify" { vec[60] = 1.0 }
    if tok == "workflow" { vec[61] = 1.0 }
    if tok == "set_alias" { vec[62] = 1.0 }
    if tok == "define_tool" { vec[63] = 1.0 }
    if tok == "list_tools" { vec[64] = 1.0 }
    if tok == "error_type" { vec[65] = 1.0 }
    if tok == "raise_error" { vec[66] = 1.0 }
    if tok == "multi_req" { vec[67] = 1.0 }
    if tok == "web_get" { vec[68] = 1.0 }
    if tok == "web_send" { vec[69] = 1.0 }
    if tok == "listen" { vec[70] = 1.0 }
    if tok == "convert" { vec[71] = 1.0 }
    if tok == "api" { vec[72] = 1.0 }
    if tok == "prompt" { vec[73] = 1.0 }
    if tok == "debug" { vec[74] = 1.0 }
    if tok == "to_upper" { vec[75] = 1.0 }
    if tok == "to_lower" { vec[76] = 1.0 }
    if tok == "trim" { vec[77] = 1.0 }
    if tok == "slice" { vec[78] = 1.0 }
    if tok == "swap" { vec[79] = 1.0 }
    if tok == "retry" { vec[80] = 1.0 }
    if tok == "map" { vec[81] = 1.0 }
    if tok == "filter" { vec[82] = 1.0 }
    if tok == "reduce" { vec[83] = 1.0 }
    if tok == "find" { vec[84] = 1.0 }
    if tok == "format" { vec[85] = 1.0 }
    if tok == "db_open" { vec[86] = 1.0 }
    if tok == "args" { vec[87] = 1.0 }
    if tok == "input" { vec[88] = 1.0 }
    i = i + 1
  }
  return vec
}

let trained_model_path = "sesi-db/trained_brain.json"
let has_trained_model = false
let weights = []
let biases = []
let database = []
let num_classes = 0

try {
  let raw = read_file(trained_model_path)
  let brain = from_json(raw)
  weights = brain["weights"]
  biases = brain["biases"]
  database = brain["database"]
  num_classes = len(database)
  has_trained_model = true
} catch (e) {}

  let query_vec = vectorize(queryText)
  
  // Forward propagation on user query across all dynamic classes
  let outputs = []
  let j = 0
  while j < num_classes {
    let sum = 0.0
    let w_row = weights[j]
    let k = 0
    while k < 89 {
      sum = sum + (query_vec[k] * w_row[k])
      k = k + 1
    }
    let o = activate(sum + biases[j])
    push(outputs, o)
    j = j + 1
  }
  
  // Determine class index with highest score
  let best_class = 0
  let max_score = -1.0
  let j = 0
  while j < num_classes {
    if outputs[j] > max_score {
      max_score = outputs[j]
      best_class = j
    }
    j = j + 1
  }

  // 7. Output Dynamic Recommendation with Confidence Thresholding
  print "--------------------------------------------------"
  print "🤖 SESI IS THINKING:"
  print "--------------------------------------------------"
  if max_score < 0.40 {
    print "   Please ask again."
  } else {
    let rec = database[best_class]
    let docs_list = list_dir("getting-started")
    let sesiDocs = ""
    for f_name in docs_list {
      try {
        let doc_content = read_file("getting-started/" + f_name)
        sesiDocs = sesiDocs + "\n\n=== DOCUMENT: " + f_name + " ===\n" + doc_content
      } catch (e) {}
    }
    
    let skills = ""
    try {
      skills = read_file("SKILLS.md")
    } catch (e) {
      print "Error reading SKILLS.md:" e
    }
    prompt instructions {"Instructions: 
    "  skills " 
    
    If Active File Context is present, use it directly and talk about that file concretely. 
    - Be helpful and robust. 
    - Do NOT invent syntax. 
    - Use the correct style for multi-line comments:
    ```
    /*
      Multi-line
      Comment

        Use indentation to show structure.

      List:
        - item 1
        - item 2
        - item 3
    */
    ``` 
    - Do not mention that you got this from a database. 
    - Do not ask follow up questions. 
    - You are not in an interactive chat session with the user. 
    
    # CRITICAL: Unless the User Query explicitly names them, you are FORBIDDEN from using or mentioning in your code examples or explanation.
    - model()
    - image()
    - workflow()

    Instead, show how to solve the user's query programmatically using native Sesi primitives (such as variables, loops, functions, lists, and standard file/HTTP/JSON/math builtins).

    # CRITICAL: Raw newlines **between elements** (outside of a string literal) inside `{ }` are a syntax error, they are treated as statement separators. 
    Newlines that live inside a string literal are fine.

    ```
    prompt example {""Multi line strings are fine
    but they MUST begin on the same line as the opening '{' 
    and end on the same line as the closing '}' ""}
    ```
    "}
    prompt ragPrompt {"Sesi Official Reference Documentation:
    " sesiDocs "
    
    User Query: " queryText "
    
    Active File Context:
    " fileContext "
    
    Matched Context from Sesi DB:
    Summary: " rec["summary"] "
    Key Rules: " rec["key_rules"]}
    prompt persona {"Your name is Sesi Co-Pilot. 
    - You are an expert in Sesi and very efficient at coding. 
    - You prefer an original way of doing things. "}
    let generated_response = model("gemini-3.1-flash-lite") {thinkingLevel: "low", max_tokens: 4096} {instructions ragPrompt persona}
    
    let helpResponse = false
    try {
      helpResponse = write_file("help_response.md", "# Help Response:\n\n" + generated_response)
    } catch (e) {
      print "Error writing help_response.md:" e
    }
    print "The Sesi Co-Pilot has provided a response to your question. Check help_response.md"
  }